generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Paciente {
  id            Int      @id @default(autoincrement())
  nombre        String
  apellido      String
  documento     String   @unique
  notas         String?
  activo        Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}