generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Odontograma {
  id          Int       @id @default(autoincrement())
  pacienteId  Int
  fecha       DateTime  @default(now())
  version     Int       @default(1)
  activo      Boolean   @default(true)
  paciente    Paciente  @relation(fields: [pacienteId], references: [id])
  dientes     Diente[]
}

model Diente {
  id             Int        @id @default(autoincrement())
  numero         Int
  odontogramaId  Int

  odontograma    Odontograma @relation(fields: [odontogramaId], references: [id])
  superficies    DiagnosticoSuperficie[]
}

model DiagnosticoSuperficie {
  id         Int     @id @default(autoincrement())
  superficie String
  diagnostico Json
  dienteId   Int

  diente     Diente  @relation(fields: [dienteId], references: [id])
}

model Paciente {
  id         Int      @id @default(autoincrement())
  nombre     String
  apellido   String
  documento  String   @unique
  telefono   String?
  notas      String?
  activo     Boolean  @default(true)

  citas        Cita[]
  finanzas     Finanza[]
  odontogramas Odontograma[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Cita {
  id            Int        @id @default(autoincrement())
  fecha         DateTime
  motivo        String
  observaciones String?
  estado        EstadoCita @default(PROGRAMADA)

  pacienteId    Int
  paciente      Paciente   @relation(fields: [pacienteId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Finanza {
  id         Int           @id @default(autoincrement())
  fecha      DateTime      @default(now())
  monto      Int           // Guardado en centavos
  tipo       TipoFinanza
  estado     EstadoFinanza @default(PENDIENTE)
  nota       String?

  pacienteId Int?
  paciente   Paciente?     @relation(fields: [pacienteId], references: [id])

  createdAt  DateTime      @default(now())
}

enum TipoFinanza {
  INGRESO
  EGRESO
}

enum EstadoFinanza {
  PENDIENTE
  PAGADA
  ATRASADA
}

enum EstadoCita {
  PROGRAMADA
  CANCELADA
  ATENDIDA
}

enum RolUsuario {
  ADMIN
  ODONTOLOGO
  AUXILIAR
  RECEPCION
}

model Usuario {
  id         Int        @id @default(autoincrement())
  nombre     String
  apellido   String
  correo     String     @unique
  password   String
  rol        RolUsuario
  telefono   String?
  documento  String?    @unique
  activo     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}