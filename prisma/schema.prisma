generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Odontograma {
  id            Int     @id @default(autoincrement())
  
}

model Paciente {
  id            Int      @id @default(autoincrement())
  nombre        String
  apellido      String
  documento     String   @unique
  telefono      String?
  notas         String?
  activo        Boolean  @default(true)

  citas         Cita[]
  finanzas      Finanza[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Cita {
  id            Int      @id @default(autoincrement())
  fecha         DateTime
  motivo        String
  observaciones String?
  estado        EstadoCita @default(PROGRAMADA)

  pacienteId Int
  paciente   Paciente @relation(fields: [pacienteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Finanza {
  id          Int           @id @default(autoincrement())
  fecha       DateTime
  monto       Decimal
  tipo        TipoFinanza
  estado      EstadoFinanza
  nota        String?

  pacienteId  Int?
  paciente    Paciente?     @relation(fields: [pacienteId], references: [id])

  createdAt   DateTime      @default(now())
}


enum TipoFinanza {
  INGRESO
  EGRESO
}

enum EstadoFinanza {
  PENDIENTE
  PAGADA
  ATRASADA
}

enum EstadoCita {
  PROGRAMADA
  CANCELADA
  ATENDIDA
}