generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum EstadoCita {
  PROGRAMADA
  CONFIRMADA
  CANCELADA
  ATENDIDA
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum RolUsuario {
  ADMIN
  ODONTOLOGO
  AUXILIAR
  RECEPCION
}

enum EstadoTratamiento {
  ACTIVO
  FINALIZADO
  PAUSADO
}

enum EstadoMovimiento {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum DocumentoTipo {
  RADIOGRAFIA
  CONSENTIMIENTO
  EXAMEN
  RECETA
  OTRO
}

//////////////////////////////////////////////////////
// PACIENTES
//////////////////////////////////////////////////////

model Paciente {
  id                      Int       @id @default(autoincrement())
  nombre                  String
  apellido                String
  documento               String    @unique
  telefono                String?
  correo                  String?
  fechaNacimiento         DateTime?
  direccion               String?
  eps                     String?
  alergias                String?
  observaciones           String?
  activo                  Boolean   @default(true)
  historiaClinicaCompleta Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  citas                   Cita[]
  tratamientos            Tratamiento[]
  odontogramas            Odontograma[]
  movimientos             Movimiento[]
  historiasClinicas       HistoriaClinica[]
  documentos              Documento[]

  @@index([documento])
}

//////////////////////////////////////////////////////
// USUARIOS (PERSONAL CLINICA)
//////////////////////////////////////////////////////

model Usuario {
  id                Int       @id @default(autoincrement())
  nombre            String
  apellido          String
  correo            String    @unique
  password          String
  rol               RolUsuario
  telefono          String?
  documento         String?   @unique
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  citas             Cita[]
  tratamientos      Tratamiento[]
  historiasClinicas HistoriaClinica[]
  documentos        Documento[]

  @@index([correo])
}

//////////////////////////////////////////////////////
// HISTORIA CLINICA
//////////////////////////////////////////////////////

model HistoriaClinica {
  id                         Int          @id @default(autoincrement())
  pacienteId                 Int
  usuarioId                  Int?
  odontogramaId              Int?

  numeroHistoria             String       @unique
  fechaApertura              DateTime     @default(now())

  estadoCivil                String?
  sexo                       String?
  ocupacion                  String?
  lugarResidencia            String?

  acompananteNombre          String?
  acompananteTelefono        String?
  acompananteParentesco      String?

  motivoConsulta             String?

  enfermedadesSistemicas     Json?
  antecedentesQuirurgicos    String?
  medicacionActual           Json?
  alergiasGenerales          String?
  antecedentesHematologicos  String?
  ginecoObstetricos          String?
  habitos                    String?
  antecedentesOdontologicos  String?

  higieneOral                Json?
  declaracionAceptada        Boolean      @default(false)

  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  paciente                   Paciente     @relation(fields: [pacienteId], references: [id])
  usuario                    Usuario?     @relation(fields: [usuarioId], references: [id])
  odontograma                Odontograma? @relation(fields: [odontogramaId], references: [id])

  @@index([pacienteId])
  @@index([usuarioId])
  @@index([odontogramaId])
}

//////////////////////////////////////////////////////
// CITAS
//////////////////////////////////////////////////////

model Cita {
  id            Int         @id @default(autoincrement())
  pacienteId    Int
  usuarioId     Int?

  fecha         DateTime
  motivo        String
  tipoAtencion  String?
  estado        EstadoCita  @default(PROGRAMADA)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  paciente      Paciente     @relation(fields: [pacienteId], references: [id])
  usuario       Usuario?     @relation(fields: [usuarioId], references: [id])
  movimientos   Movimiento[]

  @@index([pacienteId])
  @@index([usuarioId])
  @@index([fecha])
}

//////////////////////////////////////////////////////
// TRATAMIENTOS
//////////////////////////////////////////////////////

model Tratamiento {
  id             Int                 @id @default(autoincrement())
  pacienteId     Int
  usuarioId      Int?
  odontogramaId  Int?

  descripcion    String
  estado         EstadoTratamiento   @default(ACTIVO)
  monto          Float?

  fechaInicio    DateTime?
  fechaFin       DateTime?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  paciente       Paciente            @relation(fields: [pacienteId], references: [id])
  usuario        Usuario?            @relation(fields: [usuarioId], references: [id])
  odontograma    Odontograma?        @relation(fields: [odontogramaId], references: [id])

  @@index([pacienteId])
  @@index([usuarioId])
  @@index([odontogramaId])
}

//////////////////////////////////////////////////////
// FINANZAS
//////////////////////////////////////////////////////

model Movimiento {
  id              Int               @id @default(autoincrement())
  tipo            TipoMovimiento
  concepto        String
  monto           Float
  fecha           DateTime
  estado          EstadoMovimiento  @default(PENDIENTE)
  metodoPago      String?
  diagnosticoRef  String?
  nota            String?
  pacienteId      Int?
  citaId          Int?
  odontogramaId   Int?
  createdAt       DateTime          @default(now())

  paciente        Paciente?         @relation(fields: [pacienteId], references: [id])
  cita            Cita?             @relation(fields: [citaId], references: [id])
  odontograma     Odontograma?      @relation(fields: [odontogramaId], references: [id])

  @@index([pacienteId])
  @@index([citaId])
  @@index([odontogramaId])
  @@index([fecha])
  @@index([estado])
}

//////////////////////////////////////////////////////
// ODONTOGRAMA
//////////////////////////////////////////////////////

model Odontograma {
  id                 Int                @id @default(autoincrement())
  pacienteId         Int
  fecha              DateTime           @default(now())
  version            Int                @default(1)
  activo             Boolean            @default(true)
  tipo               String             @default("ADULTO")

  paciente           Paciente           @relation(fields: [pacienteId], references: [id])
  dientes            Diente[]
  historiasClinicas  HistoriaClinica[]
  movimientos        Movimiento[]
  tratamientos       Tratamiento[]

  @@index([pacienteId])
  @@index([pacienteId, activo])
  @@index([pacienteId, version])
  @@unique([pacienteId, version])
}

//////////////////////////////////////////////////////
// DIENTES
//////////////////////////////////////////////////////

model Diente {
  id             Int                    @id @default(autoincrement())
  numero         Int
  odontogramaId  Int

  odontograma    Odontograma            @relation(fields: [odontogramaId], references: [id])
  superficies    DiagnosticoSuperficie[]

  @@index([odontogramaId])
}

//////////////////////////////////////////////////////
// DIAGNOSTICO DE SUPERFICIES
//////////////////////////////////////////////////////

model DiagnosticoSuperficie {
  id          Int     @id @default(autoincrement())
  superficie  String
  diagnostico Json
  dienteId    Int

  diente      Diente  @relation(fields: [dienteId], references: [id])

  @@index([dienteId])
}

//////////////////////////////////////////////////////
// DOCUMENTOS
//////////////////////////////////////////////////////

model Documento {
  id              Int           @id @default(autoincrement())
  pacienteId      Int
  usuarioId       Int?

  nombre          String
  nombreArchivo   String        @unique
  tipo            DocumentoTipo
  fecha           DateTime?
  ruta            String
  mimetype        String
  tamanio         Int

  createdAt       DateTime      @default(now())

  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id])

  @@index([pacienteId])
  @@index([usuarioId])
}